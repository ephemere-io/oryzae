{
  "name": "@oryzae/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/app.js",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./dist/app.js"
    }
  },
  "scripts": {
    "dev": "set -a && . ../../.env && set +a && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run test/contexts",
    "test:integration": "vitest run test/integration",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "dep-cruise": "depcruise src --config .dependency-cruiser.cjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@hono/node-server": "^1.19.13",
    "@oryzae/shared": "workspace:*",
    "@supabase/supabase-js": "^2.106.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.191",
    "hono": "^4.12.23",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "dependency-cruiser": "^17.4.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
