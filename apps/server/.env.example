# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI ──
# ANTHROPIC_API_KEY は AI Gateway 経由の場合は不要
AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# ── PostHog（サーバー側 API クエリ用）──
# Personal API Key (phx_...) — https://us.posthog.com/settings/user-api-keys
POSTHOG_PERSONAL_API_KEY=

# ── Sentry（エラー監視）──
# Auth Token — https://oryzae.sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=oryzae
SENTRY_PROJECT=oryzae

# ── Upstash Redis（レート制限）──
# REST API credentials — https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Vercel（デプロイ状態取得）──
# Personal Token — https://vercel.com/account/tokens
VERCEL_TOKEN=

# ── Server ──
PORT=3000
