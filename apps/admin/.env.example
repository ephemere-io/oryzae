# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Vercel AI Gateway ──
AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# ── PostHog (client-side event tracking) ──
# Project API Key (phc_...) — https://us.posthog.com/project/378500/settings/project#variables
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Sentry (optional — error monitoring is skipped if unset)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Upstash Redis (optional — rate limiting is skipped if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
