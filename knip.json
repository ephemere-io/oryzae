{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [".claude/**", "docs/**"],
  "workspaces": {
    "apps/server": {
      "entry": ["src/app.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["src/contexts/shared/infrastructure/supabase-client.ts"],
      "vitest": true
    },
    "apps/client": {
      "next": true,
      "vitest": true,
      "ignoreDependencies": ["@testing-library/dom", "@testing-library/react"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    }
  }
}
